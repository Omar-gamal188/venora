# ──────────────────────────── Core ────────────────────────────
# development | production
NODE_ENV=development
PORT=5000

# MongoDB connection string (Atlas example:
# mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/ecommerce?retryWrites=true&w=majority)
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce

# ─────────────────────────── Secrets ──────────────────────────
# REQUIRED in production, min 32 chars each, all three must differ.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
COOKIE_SECRET=

# Access-token lifetime (e.g. 15m, 1h, 7d) and refresh-token lifetime in days
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_DAYS=30

# ──────────────────────────── CORS ────────────────────────────
# Public URL of the frontend (used for CORS + password-reset links)
CLIENT_URL=http://localhost:5173
# Extra allowed origins, comma-separated (no trailing slashes)
ALLOWED_ORIGINS=

# Set true when running behind Nginx / a load balancer (defaults to true in production)
TRUST_PROXY=false

# ─────────────────────── Requests & uploads ───────────────────
# Max JSON body size (product images are sent as base64 data URLs)
JSON_BODY_LIMIT=10mb
# Max size of a single image data URL in bytes (default 5 MB)
MAX_IMAGE_DATA_URL_BYTES=5242880

# ─────────────────────── Rate limiting ────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# ─────────────────────────── Logging ──────────────────────────
# trace | debug | info | warn | error
LOG_LEVEL=info
LOG_DIR=logs

# ──────────────────────── Dashboard admin ─────────────────────
# OPTIONAL: username treated as admin even without a DB role (mirrors
# VITE_DASHBOARD_ADMIN_USERNAME on the frontend). Prefer DB roles instead:
# create admins with `npm run admin:reset` / `npm run admin:promote`.
DASHBOARD_ADMIN_USERNAME=
# Optional extra admin usernames, comma-separated
# DASHBOARD_ADMIN_USERNAMES=alice,bob
# Create the admin on startup if missing. A strong DASHBOARD_ADMIN_PASSWORD
# (min 8 chars) is REQUIRED when enabled — there is no default password.
SEED_DASHBOARD_ADMIN=false
DASHBOARD_ADMIN_PASSWORD=
DASHBOARD_ADMIN_EMAIL=
DASHBOARD_ADMIN_FULLNAME=Dashboard Admin
# Set true (once) to overwrite an existing admin's password during seeding
UPDATE_EXISTING_ADMIN_PASSWORD=false

# ──────────────────────────── Email ───────────────────────────
# Leave EMAIL_HOST empty to log emails instead of sending (development).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Venora <no-reply@example.com>"

# ──────────────────────── MongoDB tuning ──────────────────────
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
# Set true to build indexes automatically in production (first deploy)
MONGO_AUTO_INDEX=false
